# CCodeBoX Backend Configuration

# Server
CCODEBOX_HOST=0.0.0.0
CCODEBOX_PORT=3000
DATABASE_URL=sqlite:./data/ccodebox.db

# Agent: Claude Code
CC_IMAGE=ccodebox-cc:latest
CC_API_BASE_URL=https://api.anthropic.com
CC_API_KEY=sk-ant-...
CC_DEFAULT_MODEL=claude-sonnet-4-20250514
CC_MAX_ROUNDS_LIMIT=5

# Container resource limits
CONTAINER_MEMORY_LIMIT=4294967296
CONTAINER_CPU_QUOTA=200000

# Docker socket (podman compatible)
# DOCKER_HOST=unix:///var/run/docker.sock

# Logging
RUST_LOG=info
